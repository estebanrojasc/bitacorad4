# ─── Base de datos ───────────────────────────────────────────────
# MongoDB Atlas (free tier M0) o local. Ej: mongodb+srv://user:pass@cluster/bitacora
MONGODB_URI="mongodb://127.0.0.1:27017/bitacora"

# Secreto para firmar las sesiones (JWT). Genera uno largo y aleatorio.
JWT_SECRET="cambia-esto-por-una-cadena-larga-y-aleatoria"

# Token para el endpoint de diagnóstico /api/health (elige uno largo).
DIAGNOSTICS_TOKEN="pon-aqui-un-token-secreto-para-pruebas"

# ─── Google Cloud Storage (almacenamiento de audio) ──────────────
# Bucket ya creado (ej: 404Lab).
GCS_BUCKET="404Lab"
GCS_PROJECT_ID=""
# Credenciales de la cuenta de servicio (rol: Storage Object Admin).
GCS_CLIENT_EMAIL=""
# Pega la private_key COMPLETA entre comillas. Los \n deben quedar como \n.
GCS_PRIVATE_KEY=""
# Alternativa local: en vez de las dos de arriba, puedes apuntar al JSON:
# GOOGLE_APPLICATION_CREDENTIALS="C:/ruta/a/clave.json"

# ─── DashScope / Qwen (transcripción) ────────────────────────────
DASHSCOPE_API_KEY=""
# true si tu cuenta es de región internacional (endpoint dashscope-intl)
DASHSCOPE_INTERNATIONAL="true"

# ─── Gemini (reportes + transcripción de respaldo) ───────────────
GEMINI_API_KEY=""

# ─── Guardián de cuotas (opcional, ya trae valores seguros) ──────
# STORAGE_MAX_BYTES=5368709120     # 5 GB
# EGRESS_MAX_BYTES=107374182400    # 100 GB/mes
# CLASS_A_MAX=5000                 # subidas/mes
# CLASS_B_MAX=50000                # lecturas/mes
# QWEN_MAX_SECONDS_PER_MONTH=108000
# GEMINI_MAX_REQUESTS_PER_MONTH=1500
